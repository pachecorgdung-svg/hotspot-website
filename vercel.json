{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "crons": [
    {
      "path": "/api/hotspots/update",
      "schedule": "0 9 * * *"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.9",
    "PYTHON_PACKAGE_MANAGER": "pip"
  }
}